<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:background="@drawable/screen_background_gradient"
        tools:context=".presentation.home.HomeFragment">

        <!-- Top Row with Settings & Leaderboard icons -->
        <ImageView
            android:id="@+id/iv_option"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="10dp"
            android:src="@drawable/ic_option"
            android:background="@drawable/card_glass_dark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription" />

        <!-- Logo Container -->
        <LinearLayout
            android:id="@+id/logo_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/card_player_name">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/kaun_banega"
                android:textColor="@color/accent_gold"
                android:textSize="14sp"
                android:letterSpacing="0.2"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/crorepati"
                android:textColor="@color/accent_cyan"
                android:textSize="36sp"
                android:textStyle="bold"
                android:shadowColor="@color/black"
                android:shadowRadius="10"
                android:shadowDx="2"
                android:shadowDy="2"
                android:fontFamily="sans-serif-condensed-medium" />
        </LinearLayout>

        <!-- Player Name Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_player_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@drawable/card_glass_dark"
            app:layout_constraintTop_toBottomOf="@id/logo_container"
            app:layout_constraintBottom_toTopOf="@id/btn_play_online">

            <TextView
                android:id="@+id/tv_player"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player"
                android:textSize="16sp"
                android:textColor="@color/accent_gold"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <EditText
                android:id="@+id/et_player_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:textColorHint="@color/metallic_grey"
                android:background="@android:color/transparent"
                android:hint="@string/enter_name"
                android:singleLine="true"
                android:fontFamily="sans-serif"
                app:layout_constraintTop_toBottomOf="@id/tv_player"
                tools:ignore="Autofill,LabelFor,TextFields" />

            <!-- Underline indicator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/accent_cyan"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/et_player_name" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Buttons Stack -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_play_online"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:text="@string/play_online"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/background_metallic_blue"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_player_name"
            app:layout_constraintBottom_toTopOf="@id/btn_play_offline"
            app:layout_constraintVertical_chainStyle="packed" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_play_offline"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:text="@string/play_offline"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/background_metallic_blue"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="@id/btn_play_online"
            app:layout_constraintEnd_toEndOf="@id/btn_play_online"
            app:layout_constraintTop_toBottomOf="@id/btn_play_online"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ProgressBar
            android:id="@+id/home_progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_loading_text" />

        <TextView
            android:id="@+id/tv_loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading_text"
            android:textColor="@color/accent_gold"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>