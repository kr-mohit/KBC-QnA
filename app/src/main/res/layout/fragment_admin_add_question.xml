<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:background="@drawable/screen_background_gradient"
        tools:context=".presentation.admin.AdminAddQuestionFragment">

        <!-- Top Header Bar -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/back_arrow_white"
            android:background="@drawable/card_glass_dark"
            android:padding="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_question_to_firebase"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="@id/btn_back"
            app:layout_constraintBottom_toBottomOf="@id/btn_back" />

        <!-- Card Container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_admin"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:padding="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_glass_dark"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintBottom_toTopOf="@id/btn_save"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Field: Question Text -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/enter_question"
                        android:textColor="@color/accent_gold"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_question"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/background_metallic_blue"
                        android:textColor="@color/white"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:gravity="top|start"
                        android:hint="@string/type_question_here"
                        android:textColorHint="@color/metallic_grey"
                        android:inputType="textMultiLine"
                        android:layout_marginBottom="20dp"
                        tools:ignore="Autofill" />

                    <!-- Field: Option 1 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/enter_option_1"
                        android:textColor="@color/accent_gold"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_option1"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/background_metallic_blue"
                        android:textColor="@color/white"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="15sp"
                        android:hint="@string/option_1"
                        android:textColorHint="@color/metallic_grey"
                        android:inputType="text"
                        android:layout_marginBottom="20dp"
                        tools:ignore="Autofill" />

                    <!-- Field: Option 2 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/enter_option_2"
                        android:textColor="@color/accent_gold"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_option2"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/background_metallic_blue"
                        android:textColor="@color/white"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="15sp"
                        android:hint="@string/option_2"
                        android:textColorHint="@color/metallic_grey"
                        android:inputType="text"
                        android:layout_marginBottom="20dp"
                        tools:ignore="Autofill" />

                    <!-- Field: Option 3 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/enter_option_3"
                        android:textColor="@color/accent_gold"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_option3"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/background_metallic_blue"
                        android:textColor="@color/white"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="15sp"
                        android:hint="@string/option_3"
                        android:textColorHint="@color/metallic_grey"
                        android:inputType="text"
                        android:layout_marginBottom="20dp"
                        tools:ignore="Autofill" />

                    <!-- Field: Option 4 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/enter_option_4"
                        android:textColor="@color/accent_gold"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_option4"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/background_metallic_blue"
                        android:textColor="@color/white"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="15sp"
                        android:hint="@string/option_4"
                        android:textColorHint="@color/metallic_grey"
                        android:inputType="text"
                        android:layout_marginBottom="20dp"
                        tools:ignore="Autofill" />

                    <!-- Field: Correct Option Number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/select_correct_option"
                        android:textColor="@color/accent_gold"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinner_correct_option"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/background_metallic_blue"
                        android:layout_marginBottom="20dp" />

                    <!-- Field: Prize Amount -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/select_prize_amount"
                        android:textColor="@color/accent_gold"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinner_prize_amount"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/background_metallic_blue"
                        android:layout_marginBottom="20dp" />

                    <!-- Field: Region -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/select_region"
                        android:textColor="@color/accent_gold"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinner_region"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/background_metallic_blue"
                        android:layout_marginBottom="20dp" />

                </LinearLayout>
            </ScrollView>

            <ProgressBar
                android:id="@+id/progress_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:indeterminateTint="@color/accent_gold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Save Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/add_question"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/background_metallic_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>