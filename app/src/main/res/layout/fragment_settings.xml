<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/screen_background_gradient"
        android:padding="24dp"
        tools:context=".presentation.settings.SettingsFragment">

        <!-- Top Header Bar -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/card_glass_dark"
            android:padding="12dp"
            android:src="@drawable/back_arrow_white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription,SpeakableTextPresentCheck" />

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/settings"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btn_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btn_back" />

        <!-- Settings Card Container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_glass_dark"
            android:padding="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back">

            <!-- Music Setting -->
            <TextView
                android:id="@+id/tv_music"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:text="@string/music"
                android:textColor="@color/accent_gold"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="@id/btn_music"
                app:layout_constraintEnd_toStartOf="@id/btn_music"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/btn_music" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_music"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/background_metallic_blue"
                android:minWidth="110dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="OFF" />

            <!-- SFX Audio Setting -->
            <TextView
                android:id="@+id/tv_sfx_audio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:text="@string/sfx_sound"
                android:textColor="@color/accent_gold"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="@id/btn_sfx_Audio"
                app:layout_constraintEnd_toStartOf="@id/btn_sfx_Audio"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/btn_sfx_Audio" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_sfx_Audio"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/background_metallic_blue"
                android:minWidth="110dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_music"
                tools:text="OFF" />

            <!-- Region Setting -->
            <TextView
                android:id="@+id/tv_region"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:text="@string/region"
                android:textColor="@color/accent_gold"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="@id/btn_region"
                app:layout_constraintEnd_toStartOf="@id/btn_region"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/btn_region" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_region"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/background_metallic_blue"
                android:minWidth="110dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_sfx_Audio"
                tools:text="INDIA" />

            <!-- Feedback Setting -->
            <TextView
                android:id="@+id/tv_feedback"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:text="@string/feedback_and_bugs"
                android:textColor="@color/accent_gold"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="@id/btn_feedback"
                app:layout_constraintEnd_toStartOf="@id/btn_feedback"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/btn_feedback" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_feedback"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/background_metallic_blue"
                android:minWidth="110dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/write"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_region" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_app_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:textColor="@color/metallic_grey"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="App version - KBC Q&amp;A 1.0" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>