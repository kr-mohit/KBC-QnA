<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:background="@drawable/screen_background_gradient"
        tools:context=".presentation.result.ResultFragment">

        <!-- Title / Status Container -->
        <LinearLayout
            android:id="@+id/layout_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_congratulations_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/congratulations"
                android:textColor="@color/accent_gold"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_you_won"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/you_won"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- Prize Cheque Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_prize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/card_glass_dark"
            app:layout_constraintTop_toBottomOf="@id/layout_status"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_prize_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Rs. 12,50,000"
                android:textSize="38sp"
                android:textStyle="bold"
                android:textColor="@color/accent_cyan"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:shadowColor="@color/black"
                android:shadowRadius="6"
                android:shadowDx="1"
                android:shadowDy="1"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Better Luck / Next Time Section -->
        <LinearLayout
            android:id="@+id/layout_better_luck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/card_prize">

            <TextView
                android:id="@+id/tv_better_luck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/better_luck"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/accent_gold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_next_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/next_time"
                android:textSize="22sp"
                android:textColor="@color/white"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- Sharing Buttons in a Horizontal Chain -->
        <Button
            android:id="@+id/btn_share_cheque"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:text="@string/share_cheque"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/background_metallic_blue"
            android:layout_marginEnd="6dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_share_game"
            app:layout_constraintBottom_toTopOf="@id/btn_start_again"
            app:layout_constraintTop_toTopOf="@id/btn_share_game" />

        <Button
            android:id="@+id/btn_share_game"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:text="@string/share_game"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/background_metallic_blue"
            android:layout_marginBottom="24dp"
            app:layout_constraintStart_toEndOf="@id/btn_share_cheque"
            app:layout_constraintEnd_toStartOf="@id/btn_more_games"
            app:layout_constraintBottom_toTopOf="@id/btn_start_again" />

        <Button
            android:id="@+id/btn_more_games"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:text="@string/more_games"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/background_metallic_blue"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintStart_toEndOf="@id/btn_share_game"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btn_start_again"
            app:layout_constraintTop_toTopOf="@id/btn_share_game" />

        <!-- Bottom Action Buttons Chain -->
        <Button
            android:id="@+id/btn_start_again"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/start_again"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/background_metallic_gold"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_home"
            app:layout_constraintBottom_toBottomOf="parent" />

        <Button
            android:id="@+id/btn_home"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/home"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/background_metallic_blue"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/btn_start_again"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>