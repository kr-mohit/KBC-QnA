<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:background="@drawable/screen_background_gradient"
        tools:context=".presentation.admin.AdminFragment">

        <!-- Top Header Bar -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/back_arrow_white"
            android:background="@drawable/card_glass_dark"
            android:padding="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tv_admin_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_panel"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="@id/btn_back"
            app:layout_constraintBottom_toBottomOf="@id/btn_back" />

        <!-- Options Container ScrollView -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="32dp"
            android:fillViewport="true"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Option 1: Configure Prize Levels -->
                <Button
                    android:id="@+id/btn_option_prizes"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/_1_configure_prize_levels"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="start|center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="@drawable/background_metallic_blue"
                    android:layout_marginBottom="16dp" />

                <!-- Option 2: Manage App Updates -->
                <Button
                    android:id="@+id/btn_option_updates"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/_2_manage_app_updates"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="start|center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="@drawable/card_glass_dark"
                    android:layout_marginBottom="16dp" />

                <!-- Option 3: Configure Leaderboard -->
                <Button
                    android:id="@+id/btn_option_leaderboard"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/_3_configure_leaderboard"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="start|center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="@drawable/card_glass_dark"
                    android:layout_marginBottom="16dp" />

                <!-- Option 4: Question Bank Statistics -->
                <Button
                    android:id="@+id/btn_option_stats"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/_4_question_bank_statistics"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="start|center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="@drawable/card_glass_dark"
                    android:layout_marginBottom="16dp" />

                <!-- Option 5: Maintenance Mode Configurator -->
                <Button
                    android:id="@+id/btn_option_maintenance"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/_5_maintenance_mode_config"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="start|center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="@drawable/card_glass_dark"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>
        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
