<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_glass_dark"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/audience_poll_results"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Option A Row -->
            <TextView
                android:id="@+id/tv_label_a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/option_a"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_title" />

            <ProgressBar
                android:id="@+id/progress_a"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="12dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/metallic_gold"
                app:layout_constraintBottom_toBottomOf="@id/tv_label_a"
                app:layout_constraintEnd_toStartOf="@id/tv_percent_a"
                app:layout_constraintStart_toEndOf="@id/tv_label_a"
                app:layout_constraintTop_toTopOf="@id/tv_label_a" />

            <TextView
                android:id="@+id/tv_percent_a"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:gravity="end"
                android:textColor="@color/accent_cyan"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/tv_label_a"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_label_a"
                tools:text="0%" />

            <!-- Option B Row -->
            <TextView
                android:id="@+id/tv_label_b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/option_b"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_label_a" />

            <ProgressBar
                android:id="@+id/progress_b"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="12dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/metallic_gold"
                app:layout_constraintBottom_toBottomOf="@id/tv_label_b"
                app:layout_constraintEnd_toStartOf="@id/tv_percent_b"
                app:layout_constraintStart_toEndOf="@id/tv_label_b"
                app:layout_constraintTop_toTopOf="@id/tv_label_b" />

            <TextView
                android:id="@+id/tv_percent_b"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:gravity="end"
                android:textColor="@color/accent_cyan"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/tv_label_b"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_label_b"
                tools:text="0%" />

            <!-- Option C Row -->
            <TextView
                android:id="@+id/tv_label_c"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/option_c"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_label_b" />

            <ProgressBar
                android:id="@+id/progress_c"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="12dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/metallic_gold"
                app:layout_constraintBottom_toBottomOf="@id/tv_label_c"
                app:layout_constraintEnd_toStartOf="@id/tv_percent_c"
                app:layout_constraintStart_toEndOf="@id/tv_label_c"
                app:layout_constraintTop_toTopOf="@id/tv_label_c" />

            <TextView
                android:id="@+id/tv_percent_c"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:gravity="end"
                android:textColor="@color/accent_cyan"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/tv_label_c"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_label_c"
                tools:text="0%" />

            <!-- Option D Row -->
            <TextView
                android:id="@+id/tv_label_d"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/option_d"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_label_c" />

            <ProgressBar
                android:id="@+id/progress_d"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="12dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/metallic_gold"
                app:layout_constraintBottom_toBottomOf="@id/tv_label_d"
                app:layout_constraintEnd_toStartOf="@id/tv_percent_d"
                app:layout_constraintStart_toEndOf="@id/tv_label_d"
                app:layout_constraintTop_toTopOf="@id/tv_label_d" />

            <TextView
                android:id="@+id/tv_percent_d"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:gravity="end"
                android:textColor="@color/accent_cyan"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/tv_label_d"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_label_d"
                tools:text="0%" />

            <!-- Close Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_close"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/background_metallic_blue"
                android:text="@string/ok"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_label_d" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>